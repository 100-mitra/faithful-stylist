# Copy to .env (gitignored) and fill in. The app and tests run WITHOUT any key by
# default (STYLIST_LLM defaults to "fake"); a key is only needed for real LLM runs.

# Which LLM provider the pipeline uses:
#   fake      -> deterministic stub, no network, no key (DEFAULT; used by CI/tests)
#   anthropic -> real Claude (needs ANTHROPIC_API_KEY below)
#   cassette  -> replay recorded real responses from eval/cassettes (no key)
STYLIST_LLM=fake

# Required only when STYLIST_LLM=anthropic.
ANTHROPIC_API_KEY=

# Which text embedder to use:
#   hashing -> dependency-light, offline, deterministic (DEFAULT)
#   minilm  -> sentence-transformers all-MiniLM-L6-v2 (needs the `st` extra)
#   voyage  -> Voyage API (needs VOYAGE_API_KEY and the `voyage` extra)
STYLIST_EMBEDDER=hashing
# VOYAGE_API_KEY=

# Hard ceiling on spend per process for real LLM runs (USD). The provider raises
# before exceeding it. Keeps eval runs cheap and bounded.
STYLIST_LLM_BUDGET_USD=1.00
